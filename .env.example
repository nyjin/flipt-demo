# Copy to `.env` and fill in. `.env` is gitignored.
#
# docker compose reads this file automatically.

# --- GrowthBook backend integration ---------------------------------------
# SDK Connection client key from the GrowthBook UI
# (Settings → SDK Connections → create one, then copy the "Client Key").
# Leave empty before GrowthBook is set up — the backend still boots and just
# falls back to off for GrowthBook evaluations.
GROWTHBOOK_CLIENT_KEY=

# --- GrowthBook server secrets (local/dev only) ---------------------------
# Used by the growthbook container. Replace with long random strings for any
# shared/non-throwaway environment. Defaults are baked into docker-compose.yml.
GROWTHBOOK_JWT_SECRET=local-dev-jwt-secret-change-me
GROWTHBOOK_ENCRYPTION_KEY=local-dev-encryption-key-change-me
